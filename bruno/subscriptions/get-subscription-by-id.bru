meta {
  name: Get Subscription By Id
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/user/subscriptions/{{subscriptionId}}?page={{page}}&limit={{limit}}&status={{transactionStatus}}&fromDate={{fromDate}}&toDate={{toDate}}
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}
