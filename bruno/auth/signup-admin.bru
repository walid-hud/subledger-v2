meta {
  name: Signup Admin
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{adminLoginEmail}}",
    "password": "{{adminLoginPassword}}",
    "role": "admin",
    "username": "adminuser01"
  }
}
