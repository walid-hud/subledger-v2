meta {
  name: Login Admin
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{adminLoginEmail}}",
    "password": "{{adminLoginPassword}}"
  }
}

docs {
  Save data.token from response into adminToken variable.
}
